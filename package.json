{
  "name": "anonymous-chat-backend",
  "version": "1.0.0",
  "description": "Backend-only anonymous group chat API with REST, GraphQL, WebSocket, Prisma, PostgreSQL, OpenAPI, and CI.",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "prebuild": "node ./node_modules/prisma/build/index.js generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:push": "node ./node_modules/prisma/build/index.js db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "postgresql",
    "graphql",
    "socket.io"
  ],
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-playground-middleware-express": "^1.7.23",
    "http-status-codes": "^2.3.0",
    "socket.io": "^4.8.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.8.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
